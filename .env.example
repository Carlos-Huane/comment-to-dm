# =============================================================================
# Copiar a `.env` (gitignored) y rellenar con valores reales.
# En Vercel producción: setear estas mismas vars en Project Settings → Environment.
# Las creds reales viven también en hs-carrusel/.env.local y _scripts/publish-ig/.env
# =============================================================================

# --- Instagram Graph API ---
IG_USER_ID=17841...
IG_ACCESS_TOKEN=IGAA...
GRAPH_API_VERSION=v23.0

# --- Webhook ---
# Token que YO defino (string random largo). Meta lo manda en el GET de handshake
# para confirmar que controlo este endpoint. Generar con: openssl rand -hex 32
WEBHOOK_VERIFY_TOKEN=replace-with-random-string

# App Secret de la app de Meta Developer (settings → basic → "App Secret").
# Usado para verificar la firma HMAC SHA256 de cada POST de Meta (header X-Hub-Signature-256).
# Si está vacío, se loguea warning y se acepta el request — solo para desarrollo local.
IG_APP_SECRET=

# --- Configuración del bot ---
# Palabra clave a detectar en comentarios (case-insensitive). Default: "link"
# UNA sola global — la URL específica sale de content/post-links.json según el post.
KEYWORD=link

# Template default del DM. Soporta placeholders {username} y {url}.
# Se puede sobreescribir por post agregando "message" a la entrada en post-links.json.
DM_MESSAGE_TEMPLATE=Hey @{username}! Acá tienes lo que pediste: {url}

# --- Admin ---
# Secret para proteger endpoints admin como /api/list-recent-posts.
# Si vacío, esos endpoints devuelven 503. Generar con:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=
